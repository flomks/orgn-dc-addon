{
  "manifest_version": 3,
  "name": "ORGN Discord Bridge",
  "version": "2.0.0",
  "description": "Show your ORGN CDE activity as Discord Rich Presence. Requires the ORGN Bridge desktop app.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{discord-richpresence-webapp@extension}",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "*://*.orgn.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
