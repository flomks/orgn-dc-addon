{
  "name": "orgn-discord-bridge",
  "version": "1.1.0",
  "description": "ORGN Discord Bridge - Desktop app + browser extension for Discord Rich Presence in web applications",
  "main": "desktop-app/main.js",
  "scripts": {
    "app": "electron desktop-app/main.js",
    "app:dev": "electron desktop-app/main.js --dev",
    "diagnose": "node scripts/diagnose.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "browser-extension",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron": "^40.6.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.orgn.discord.bridge",
    "productName": "ORGN Discord Bridge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop-app/**/*",
      "lib/**/*",
      "extension/icons/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "extension/icons/icon128.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "extension/icons/icon128.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "extension/icons/icon128.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
